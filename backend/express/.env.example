# NexusAI API — copy to .env and fill values (never commit real keys)

NODE_ENV=production
PORT=3001
FRONTEND_URL=https://nexus-ai.group

# AI providers — keys are SERVER-SIDE ONLY (never expose in frontend)
# Primary: Gemini (gemini-1.5-flash) | Fallback: Groq (llama-3.1-8b-instant)
GEMINI_API_KEY=
# Google retired bare gemini-1.5-flash; use current Flash (gemini-2.5-flash or gemini-flash-latest)
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Optional Gemini key rotation
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=

AI_PRIMARY_PROVIDER=gemini
AI_FALLBACK_PROVIDER=groq
AI_EXTENDED_FALLBACK=false
AI_REQUEST_TIMEOUT_MS=28000
AI_PLATFORM_COST_SOFT_USD=3
AI_PLATFORM_COST_HARD_USD=5

# Database (set DATABASE_URL OR all DB_* — app prefers DATABASE_URL)
DATABASE_URL=postgresql://postgres:yourpassword@127.0.0.1:5432/nexusai
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=nexusai
DB_USER=postgres
DB_PASSWORD=
MIGRATE_ON_START=true

# Redis (BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Business Context Intelligence (embeddings + async crawl)
GEMINI_EMBEDDING_MODEL=text-embedding-004
BCI_EMBEDDING_DIM=768
BCI_CRAWL_MAX_PAGES=12

JWT_SECRET=change-me-in-production

# Engineering Agent — git clone for code search / edits
ENGINEERING_REPO_ROOT=/var/www/nexusai-repo
# When clone has no backend/express (e.g. shallow GitHub main), point builds at deployed API
ENGINEERING_BACKEND_ROOT=/var/www/nexusai-api
