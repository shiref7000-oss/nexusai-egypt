{
  "name": "nexusai-api",
  "version": "1.0.0",
  "description": "NexusAI Egyptian E-Commerce OS Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc",
    "migrate": "node dist/db/runMigrations.js",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "start:prod": "pm2 start ecosystem.config.cjs",
    "stop:prod": "pm2 stop ecosystem.config.js",
    "restart:prod": "pm2 restart ecosystem.config.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.49.0",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "playwright": "^1.49.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.10",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "groq-sdk": "^0.12.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.21.0",
    "xlsx": "^0.18.5",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.11.10",
    "tsx": "^4.22.1",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
